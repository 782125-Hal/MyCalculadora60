# Copia este archivo como .env y completa los valores reales
# NUNCA subas el archivo .env a GitHub

# Clave secreta de Django (genera una nueva en producción)
# Puedes generar una con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=tu_clave_secreta_aqui

# Modo debug: True en desarrollo local, False en producción
DEBUG=True

# Hosts permitidos, separados por coma. En producción NO uses '*'.
# Railway: si defines RAILWAY_PUBLIC_DOMAIN el dominio se agrega automáticamente.
# Ejemplo: miapp.up.railway.app,www.midominio.com
ALLOWED_HOSTS=

# Orígenes de confianza para CSRF (necesario detrás del proxy HTTPS de Railway).
# Debe incluir el esquema. Ejemplo: https://miapp.up.railway.app
CSRF_TRUSTED_ORIGINS=

# Railway lo inyecta automáticamente; en local puedes dejarlo vacío.
RAILWAY_PUBLIC_DOMAIN=

# Rate limiting del login (django-axes)
AXES_FAILURE_LIMIT=5     # intentos fallidos antes de bloquear
AXES_COOLOFF_TIME=1      # horas que dura el bloqueo

# URL de la base de datos (Railway la provee automáticamente al agregar PostgreSQL)
# Formato: postgres://usuario:password@host:puerto/nombre_db
# En desarrollo puedes omitirla para usar SQLite local
DATABASE_URL=postgres://usuario:password@host:5432/nombre_db
